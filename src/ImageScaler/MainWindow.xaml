<Window x:Class="ImageScaler.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:ImageScaler"
        Title="Simple Image Scaler" Height="640" Width="1080"
        Background="#FF20232A" FontFamily="Segoe UI" FontSize="13">

    <TabControl Background="Transparent" BorderThickness="0" Margin="8">
        <TabItem Header="{Binding [TabCompress], Source={x:Static local:Loc.Instance}}">
            <Grid Margin="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="300"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- LINKS: Eingang -->
                <DockPanel Grid.Column="0" Margin="0,0,12,0">
                    <TextBlock DockPanel.Dock="Top" Text="{Binding [Original], Source={x:Static local:Loc.Instance}}" Style="{StaticResource Header}"/>
                    <Grid>
                        <ListBox x:Name="InputList" Style="{StaticResource CardList}" AllowDrop="True"
                                 DragOver="InputList_DragOver" Drop="InputList_Drop"/>
                        <TextBlock x:Name="InputHint" IsHitTestVisible="False"
                                   Text="{Binding [DragHint], Source={x:Static local:Loc.Instance}}" Foreground="#FF6B7280"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Grid>
                </DockPanel>

                <!-- MITTE: Einstellungen -->
                <Border Grid.Column="1" Background="#FF22262E" CornerRadius="8" Padding="16">
                    <StackPanel>
                        <TextBlock Text="{Binding [Settings], Source={x:Static local:Loc.Instance}}" Style="{StaticResource Header}"/>

                        <TextBlock Text="{Binding [Language], Source={x:Static local:Loc.Instance}}" Foreground="#FF9AA4B2" Margin="4,8,0,4"/>
                        <ComboBox x:Name="LanguageBox" SelectionChanged="LanguageBox_SelectionChanged">
                            <ComboBoxItem Content="English" Tag="en" IsSelected="True"/>
                            <ComboBoxItem Content="Deutsch" Tag="de"/>
                        </ComboBox>

                        <TextBlock Text="{Binding [TargetSize], Source={x:Static local:Loc.Instance}}" Foreground="#FF9AA4B2" Margin="4,16,0,4"/>
                        <ComboBox x:Name="TargetPreset" SelectionChanged="TargetPreset_SelectionChanged">
                            <ComboBoxItem Content="8 MB"/>
                            <ComboBoxItem Content="10 MB" IsSelected="True"/>
                            <ComboBoxItem Content="25 MB"/>
                            <ComboBoxItem Content="50 MB"/>
                            <ComboBoxItem Content="{Binding [Custom], Source={x:Static local:Loc.Instance}}"/>
                        </ComboBox>

                        <TextBlock Text="{Binding [CustomSize], Source={x:Static local:Loc.Instance}}" Foreground="#FF9AA4B2" Margin="4,12,0,4"/>
                        <TextBox x:Name="CustomMb" IsEnabled="False" Text="10" Padding="6"/>

                        <TextBlock Text="{Binding [Format], Source={x:Static local:Loc.Instance}}" Foreground="#FF9AA4B2" Margin="4,12,0,4"/>

                        <Button x:Name="CompressButton" Content="{Binding [Compress], Source={x:Static local:Loc.Instance}}" Margin="0,16,0,0" Click="CompressButton_Click"/>
                        <ProgressBar x:Name="Progress" Height="6" Margin="0,12,0,0" Minimum="0" Background="#FF2C313A" Foreground="#FF3B82F6" BorderThickness="0"/>
                        <TextBlock x:Name="StatusLabel" Foreground="#FF9AA4B2" Margin="4,10,0,0" TextWrapping="Wrap"/>

                        <Button x:Name="ClearButton" Content="{Binding [ClearList], Source={x:Static local:Loc.Instance}}" Margin="0,16,0,0"
                                Background="#FF374151" Click="ClearButton_Click"/>
                    </StackPanel>
                </Border>

                <!-- RECHTS: Ergebnis -->
                <DockPanel Grid.Column="2" Margin="12,0,0,0">
                    <TextBlock DockPanel.Dock="Top" Text="{Binding [Result], Source={x:Static local:Loc.Instance}}" Style="{StaticResource Header}"/>
                    <Grid>
                        <ListBox x:Name="OutputList" Style="{StaticResource CardList}" SelectionMode="Extended"
                                 PreviewMouseLeftButtonDown="OutputList_PreviewMouseLeftButtonDown"
                                 MouseMove="OutputList_MouseMove"/>
                        <TextBlock x:Name="OutputHint" IsHitTestVisible="False"
                                   Text="{Binding [OutputHint], Source={x:Static local:Loc.Instance}}" Foreground="#FF6B7280"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Grid>
                </DockPanel>
            </Grid>
        </TabItem>

        <TabItem Header="{Binding [TabSlice], Source={x:Static local:Loc.Instance}}">
            <local:SliceView/>
        </TabItem>
    </TabControl>
</Window>
